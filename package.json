{
  "name": "filemaker-sync-system",
  "version": "1.0.0",
  "description": "FileMaker Database Synchronization System with S3 JEDI folder sync, FileMaker Server publishing, and Web Direct verification",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node scripts/hourly-sync-cron.ts",
    "build": "tsc",
    "start": "node dist/scripts/hourly-sync-cron.js",
    "sync": "ts-node scripts/manual-sync.ts",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "cron:start": "pm2 start dist/scripts/hourly-sync-cron.js --name 'filemaker-sync-cron' --cron '0 * * * *'",
    "cron:stop": "pm2 stop filemaker-sync-cron",
    "cron:status": "pm2 status filemaker-sync-cron",
    "cron:logs": "pm2 logs filemaker-sync-cron"
  },
  "dependencies": {
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "node-cron": "^3.0.2",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.15.11",
    "@typescript-eslint/eslint-plugin": "^5.59.2",
    "@typescript-eslint/parser": "^5.59.2",
    "eslint": "^8.39.0",
    "jest": "^29.5.0",
    "prettier": "^2.8.8",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.2"
  },
  "keywords": [
    "filemaker",
    "sync",
    "jedi",
    "s3",
    "database",
    "automation"
  ],
  "author": "JEDI Systems",
  "license": "MIT"
}
