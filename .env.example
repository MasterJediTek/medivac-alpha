# FileMaker Server Configuration
FILEMAKER_SERVER_HOST=iskooledu.fmcloud.fm
FILEMAKER_SERVER_USERNAME=admin
FILEMAKER_SERVER_PASSWORD=your_password_here

# JEDI Folder Configuration (Central Root)
JEDI_ROOT_PATH=/jedi/central
JEDI_SYNC_PATH=/jedi/central/filemaker-databases
JEDI_BACKUP_PATH=/jedi/central/backups
JEDI_METADATA_PATH=/jedi/central/metadata

# Web Direct Publishing
FILEMAKER_WEB_DIRECT_URL=https://iskooledu.fmcloud.fm/fmi/webd

# JEDI Council Notifications
JEDI_COUNCIL_EMAIL=council@jedi.local
JEDI_MASTER_EMAILS=master1@jedi.local,master2@jedi.local
JEDI_GRAND_MASTER_EMAILS=grandmaster@jedi.local

# Sync Configuration
FILEMAKER_SOURCE_DIR=/home/ubuntu/projects/filemaker-databases/files
FILEMAKER_LOG_DIR=/var/log/filemaker-sync

# Monitoring
ENABLE_DETAILED_LOGGING=true
ARCHIVE_LOGS_AFTER_DAYS=30
